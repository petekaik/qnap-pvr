@startuml C4_Container_PVR
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title PVR Stack - Container Diagram

Person(user, "Home user", "Watches live TV and recordings")

System_Boundary(host, "Docker Host (QNAP / NAS)") {
    Container(tvh, "tvheadend", "LinuxServer TVHeadend", "Records .ts files, manages EPG and tuners")
    Container(jf, "jellyfin", "Jellyfin", "Serves live TV and recordings")
    Container(trans, "transcoder", "Alpine + ffmpeg + dcron", "Transcodes .ts to .mp4 off-peak")
    ContainerDb(queue, "transcode queue", "JSONL file", "Pending and done recordings")
    ContainerDb(rec, "recordings", "Host filesystem", "Original .ts files")
    ContainerDb(mp4, "transcoded", "Host filesystem", "H.264/AAC .mp4 files")
}

System_Ext(antenna, "DVB-T/T2 antenna", "Broadcast signal")
System_Ext(net, "Home network", "HTTP / DLNA clients")

Rel(antenna, tvh, "Broadcast signal")
Rel(user, net, "Watches")
Rel(net, jf, "Streams and downloads", "HTTP")
Rel(tvh, rec, "Writes .ts")
Rel(tvh, queue, "Appends via post-processor")
Rel(trans, queue, "Reads pending items")
Rel(trans, rec, "Reads .ts")
Rel(trans, mp4, "Writes .mp4")
Rel(jf, rec, "Reads .ts")
Rel(jf, mp4, "Reads .mp4")

@enduml
