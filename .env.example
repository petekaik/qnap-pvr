# Base directory for all PVR data on the Docker host.
# This is mounted into every container.
DATA=/path/to/pvr/data

# Timezone for all containers.
TZ=Europe/Helsinki

# TVHeadend macvlan IPv4 address on the external Docker network (eth1).
# Pick a free address in your macvlan subnet (the subnet you used
# in `docker network create --subnet=...` during quick-start step 3).
LOCAL_IPV4_1=10.0.10.11

# Jellyfin macvlan IPv4 address on the external Docker network (eth1).
# Same subnet as LOCAL_IPV4_1, different host octet.
LOCAL_IPV4_2=10.0.10.12

# Jellyfin API key (generate from Jellyfin dashboard: Dashboard -> Advanced -> API Keys).
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# Cron schedule for the transcoder container.
# Default: daily at 02:00. During testing you can use "0 * * * *" (every hour).
TRANSCODE_CRON=0 2 * * *

# TVHeadend process UID/GID inside the container.
# The qnap-pvr fork's upstream-style image runs as the in-image
# 'tvheadend' user (UID 100, GID 101 by default). It expects to
# read the bind-mounted ${DATA}/tvheadend/config tree, so the
# matching host uid/gid needs to own (or at least be able to
# read) that directory. LinuxServer.io's PUID/PGID would normally
# handle this via a chown entrypoint, but the fork has none.
# Override in .env if your config tree is owned by something else.
# TVH_PUID=100
# TVH_PGID=101